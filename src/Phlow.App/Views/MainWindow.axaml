<suki:SukiWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Phlow.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:suki="using:SukiUI.Controls"
        xmlns:views="using:Phlow.App.Views"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="Phlow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Phlow"
        Width="1920" Height="1080"
        MinWidth="1280" MinHeight="720">

    <suki:SukiWindow.RightWindowTitleBarControls>
        <Button Classes="Basic" Click="About_Click" ToolTip.Tip="About Phlow" Padding="8,4">
            <TextBlock Text="ℹ" FontSize="16"/>
        </Button>
        <Button Classes="Basic" Click="ToggleTheme_Click" ToolTip.Tip="Toggle theme" Padding="8,4">
            <TextBlock Text="🌓" FontSize="16"/>
        </Button>
    </suki:SukiWindow.RightWindowTitleBarControls>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <suki:SukiSideMenu IsMenuExpanded="True">
        <suki:SukiSideMenu.HeaderContent>
            <Panel>
                <StackPanel IsVisible="{Binding $parent[suki:SukiSideMenu].IsMenuExpanded}"
                            HorizontalAlignment="Center" Margin="12,10,12,8" Spacing="6">
                    <Image Source="{StaticResource PhlowLogo}" Width="80" Height="80" HorizontalAlignment="Center"/>
                    <TextBlock Text="Phlow" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,-20,0,50"/>
                </StackPanel>
                <Image IsVisible="{Binding !$parent[suki:SukiSideMenu].IsMenuExpanded}"
                       Source="{StaticResource PhlowLogo}" Width="28" Height="28"
                       HorizontalAlignment="Center" Margin="0,8"/>
            </Panel>
        </suki:SukiSideMenu.HeaderContent>
        
        <suki:SukiSideMenu.FooterContent>
            <suki:GlassCard Margin="8" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="SOURCE" FontSize="10" Opacity="0.6" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding InputSources}" 
                              SelectedItem="{Binding SelectedInputSource}"
                              HorizontalAlignment="Stretch" MinWidth="0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            ToolTip.Tip="{Binding Path}">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="📁 Browse" Classes="Flat" FontSize="11" Padding="8,4"
                                Click="BrowseFolder_Click"/>
                        <Button Content="⟳" Classes="Flat" FontSize="11" Padding="8,4"
                                Command="{Binding RefreshDrivesCommand}" ToolTip.Tip="Refresh drives"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FileCountStatus}" Opacity="0.6" FontSize="10"/>
                </StackPanel>
            </suki:GlassCard>
        </suki:SukiSideMenu.FooterContent>

        <suki:SukiSideMenu.Items>
            <suki:SukiSideMenuItem Header="Transfer Queue">
                <suki:SukiSideMenuItem.Icon>
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding $parent[suki:SukiSideMenuItem].Foreground}"
                                  Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"/>
                        </Canvas>
                    </Viewbox>
                </suki:SukiSideMenuItem.Icon>
                <suki:SukiSideMenuItem.PageContent>
                    <DockPanel>
                        <suki:GlassCard DockPanel.Dock="Top" Margin="16,16,16,0" Padding="16,12">
                            <Grid>
                                <TextBlock Text="Transfer Queue" FontSize="20" FontWeight="SemiBold"
                                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal" Spacing="16"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="PROFILE" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                        <ComboBox ItemsSource="{Binding Profiles}" 
                                                  SelectedItem="{Binding SelectedProfile}" MinWidth="140">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <suki:GlassCard Padding="10,6" IsVisible="{Binding HasConflicts}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⚠" Foreground="#f59e0b" FontSize="14"/>
                                            <TextBlock Text="{Binding ConflictCount, StringFormat='{}{0} Conflicts'}" 
                                                       Foreground="#f59e0b" FontSize="13"/>
                                        </StackPanel>
                                    </suki:GlassCard>
                                    <Button Classes="Flat Accent" Command="{Binding StartDownloadCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="▶" FontSize="12"/>
                                            <TextBlock Text="Start Download" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </suki:GlassCard>
                        <views:TransferQueueView Margin="16" DataContext="{Binding TransferQueueViewModel}"/>
                    </DockPanel>
                </suki:SukiSideMenuItem.PageContent>
            </suki:SukiSideMenuItem>
            
            <suki:SukiSideMenuItem Header="Preferences">
                <suki:SukiSideMenuItem.Icon>
                    <Viewbox Width="24" Height="24">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{Binding $parent[suki:SukiSideMenuItem].Foreground}"
                                  Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                        </Canvas>
                    </Viewbox>
                </suki:SukiSideMenuItem.Icon>
                <suki:SukiSideMenuItem.PageContent>
                    <DockPanel>
                        <suki:GlassCard DockPanel.Dock="Top" Margin="16,16,16,0" Padding="16,12">
                            <TextBlock Text="Preferences" FontSize="20" FontWeight="SemiBold"/>
                        </suki:GlassCard>
                        <views:SettingsView Margin="16" DataContext="{Binding SettingsViewModel}"/>
                    </DockPanel>
                </suki:SukiSideMenuItem.PageContent>
            </suki:SukiSideMenuItem>
        </suki:SukiSideMenu.Items>
    </suki:SukiSideMenu>
</suki:SukiWindow>
