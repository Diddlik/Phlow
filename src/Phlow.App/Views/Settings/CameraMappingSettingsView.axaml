<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Phlow.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:suki="using:SukiUI.Controls"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
             x:Class="Phlow.App.Views.Settings.CameraMappingSettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Spacing="16">
        <StackPanel>
            <TextBlock Text="Camera Mapping" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Map camera models to specific tokens." Opacity="0.6" FontSize="13"/>
        </StackPanel>
        
        <suki:GlassCard>
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ToggleSwitch IsChecked="{Binding IdentifyCameraBySerial}" OnContent="" OffContent=""/>
                    <TextBlock Text="Identify camera using serial number" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Text="Detected Camera" Opacity="0.6" FontSize="12"/>
                    <TextBox Text="{Binding DetectedCamera}" IsReadOnly="True"/>
                </StackPanel>
            </StackPanel>
        </suki:GlassCard>
    </StackPanel>
</UserControl>
